/*
 * Generated by CMake from the gyan prebuilt tree (libavutil/ffversion.h) and from
 * ffplay/ffmpeg -version or -buildconf output. License and component switches follow
 * gyan full_build (GPLv3, libav* + SDL2). CONFIG_LIBPLACEBO is 0 so libplacebo is not
 * linked (Vulkan renderer path disabled for this standalone build).
 */
#ifndef FFPLAY_GENERATED_CONFIG_H
#define FFPLAY_GENERATED_CONFIG_H

#define FFMPEG_VERSION "@FFMPEG_VERSION_STR@"
#define FFMPEG_CONFIGURATION "@FFMPEG_CONFIGURATION_ESC@"
#define CC_IDENT "@CC_IDENT_ESC@"
#define CONFIG_THIS_YEAR @CONFIG_THIS_YEAR@

#define FFMPEG_DATADIR "."

#define CONFIG_NONFREE 0
#define CONFIG_GPLV3 1
#define CONFIG_GPL 0
#define CONFIG_LGPLV3 0

#define CONFIG_AVUTIL 1
#define CONFIG_AVCODEC 1
#define CONFIG_AVFORMAT 1
#define CONFIG_AVDEVICE 1
#define CONFIG_AVFILTER 1
#define CONFIG_SWSCALE 1
#define CONFIG_SWRESAMPLE 1

#define CONFIG_SDL2 1
#define CONFIG_LIBPLACEBO 0

#define HAVE_SETDLLDIRECTORY 1
#define HAVE_COMMANDLINETOARGVW 1
#define HAVE_GETMODULEHANDLE 1
#define HAVE_WINRT 0
#define HAVE_GETENV 1

#endif /* FFPLAY_GENERATED_CONFIG_H */
